{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/stardew-living-rpg-mod/npc-command-schema.json",
  "title": "NPC Command Envelope",
  "type": "object",
  "required": ["intent_id", "npc_id", "command", "arguments"],
  "properties": {
    "intent_id": {
      "type": "string",
      "description": "Idempotency key for dedupe"
    },
    "npc_id": {
      "type": "string"
    },
    "command": {
      "type": "string",
      "enum": [
        "propose_quest",
        "adjust_reputation",
        "shift_interest_influence",
        "apply_market_modifier",
        "publish_rumor",
        "publish_article",
        "record_memory_fact",
        "record_town_event",
        "adjust_town_sentiment"
      ]
    },
    "arguments": {
      "type": "object"
    },
    "reason": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": { "properties": { "command": { "const": "propose_quest" } } },
      "then": {
        "properties": {
          "arguments": {
            "type": "object",
            "required": ["template_id", "target", "urgency"],
            "properties": {
              "template_id": {
                "type": "string",
                "enum": ["gather_crop", "deliver_item", "mine_resource", "social_visit"]
              },
              "target": { "type": "string" },
              "urgency": { "type": "string", "enum": ["low", "medium", "high"] },
              "reward_hint": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": { "properties": { "command": { "const": "adjust_reputation" } } },
      "then": {
        "properties": {
          "arguments": {
            "type": "object",
            "required": ["target", "delta"],
            "properties": {
              "target": { "type": "string" },
              "delta": { "type": "integer", "minimum": -10, "maximum": 10 },
              "reason": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": { "properties": { "command": { "const": "shift_interest_influence" } } },
      "then": {
        "properties": {
          "arguments": {
            "type": "object",
            "required": ["interest", "delta"],
            "properties": {
              "interest": {
                "type": "string",
                "enum": ["farmers_circle", "shopkeepers_guild", "adventurers_club", "nature_keepers"]
              },
              "delta": { "type": "integer", "minimum": -5, "maximum": 5 },
              "reason": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": { "properties": { "command": { "const": "apply_market_modifier" } } },
      "then": {
        "properties": {
          "arguments": {
            "type": "object",
            "required": ["crop", "delta_pct", "duration_days"],
            "properties": {
              "crop": { "type": "string" },
              "delta_pct": { "type": "number", "minimum": -0.15, "maximum": 0.15 },
              "duration_days": { "type": "integer", "minimum": 1, "maximum": 7 },
              "reason": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": { "properties": { "command": { "const": "publish_rumor" } } },
      "then": {
        "properties": {
          "arguments": {
            "type": "object",
            "required": ["topic", "confidence", "target_group"],
            "properties": {
              "topic": { "type": "string" },
              "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
              "target_group": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": { "properties": { "command": { "const": "publish_article" } } },
      "then": {
        "properties": {
          "arguments": {
            "type": "object",
            "required": ["title", "content", "category"],
            "properties": {
              "title": { "type": "string", "minLength": 1, "maxLength": 80 },
              "content": { "type": "string", "minLength": 1, "maxLength": 120 },
              "category": { "type": "string", "enum": ["community", "market", "social", "nature"] }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": { "properties": { "command": { "const": "record_memory_fact" } } },
      "then": {
        "properties": {
          "arguments": {
            "type": "object",
            "required": ["category", "text"],
            "properties": {
              "category": { "type": "string", "enum": ["preference", "promise", "event", "relationship"] },
              "text": { "type": "string", "minLength": 8, "maxLength": 140 },
              "weight": { "type": "integer", "minimum": 1, "maximum": 5 }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": { "properties": { "command": { "const": "record_town_event" } } },
      "then": {
        "properties": {
          "arguments": {
            "type": "object",
            "required": ["kind", "summary", "location", "severity", "visibility"],
            "properties": {
              "kind": { "type": "string", "enum": ["market", "social", "nature", "incident", "community"] },
              "summary": { "type": "string", "minLength": 12, "maxLength": 160 },
              "location": { "type": "string", "minLength": 2, "maxLength": 40 },
              "severity": { "type": "integer", "minimum": 1, "maximum": 5 },
              "visibility": { "type": "string", "enum": ["local", "public"] },
              "tags": {
                "type": "array",
                "maxItems": 5,
                "items": { "type": "string", "minLength": 2, "maxLength": 24 }
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": { "properties": { "command": { "const": "adjust_town_sentiment" } } },
      "then": {
        "properties": {
          "arguments": {
            "type": "object",
            "required": ["axis", "delta"],
            "properties": {
              "axis": { "type": "string", "enum": ["economy", "community", "environment"] },
              "delta": { "type": "integer", "minimum": -5, "maximum": 5 },
              "reason": { "type": "string", "maxLength": 120 }
            },
            "additionalProperties": false
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
